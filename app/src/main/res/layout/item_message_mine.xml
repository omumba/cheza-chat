<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:paddingVertical="2dp"
    android:paddingStart="64dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Reply preview -->
        <LinearLayout
            android:id="@+id/replyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_reply_mine"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone">
            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="#9FE1CB"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/tvReplyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#B2F5EA"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!--
            FIX: time+tick are INSIDE the bubble using RelativeLayout.
            paddingBottom="24dp" reserves space so text never slides under the timestamp.
            paddingEnd="52dp" stops text running under timestamp on last line.
        -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_mine">

            <TextView
                android:id="@+id/tvContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="24dp"
                android:textSize="15sp"
                android:textColor="@color/text_on_bubble_mine"
                android:lineSpacingExtra="2dp"
                android:minWidth="60dp"
                android:maxWidth="240dp" />

            <!-- Time + tick pinned bottom-end INSIDE the bubble -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#80FFFFFF" />

                <ImageView
                    android:id="@+id/ivTick"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_tick_sending"
                    android:layout_marginStart="3dp"
                    android:contentDescription="Status" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
