<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ChezaChat" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSurface">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_secondary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <style name="Theme.ChezaChat.Splash" parent="Theme.ChezaChat">
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- Message bubble text styles -->
    <style name="MessageText.Mine">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="MessageText.Theirs">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>
	<style name="MessageText">
    <item name="android:textSize">14sp</item>
    <item name="android:textColor">@android:color/black</item>
    <item name="android:fontFamily">@font/inter_regular</item>
</style>

</resources>
