<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Example custom button style -->
    <style name="Widget.ChezaChat.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="Widget.ChezaChat.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/til_stroke_selector</item>
        <item name="boxBackgroundColor">@color/bg_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxStrokeWidth">1.5dp</item>
    </style>

</resources>